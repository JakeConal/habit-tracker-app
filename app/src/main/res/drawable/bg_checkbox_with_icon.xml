<?xml version="1.0" encoding="utf-8"?>
<!-- Enhanced checkbox drawable with checkmark icon -->
<!-- Checked: Solid green circle with white checkmark -->
<!-- Unchecked: Light grey outlined circle -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked/Completed State -->
    <item android:state_checked="true">
        <layer-list>
            <!-- Green Circle Background -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#4CAF50" />
                    <size android:width="32dp" android:height="32dp" />
                </shape>
            </item>
            <!-- White Checkmark Icon -->
            <item
                android:width="20dp"
                android:height="20dp"
                android:gravity="center"
                android:drawable="@drawable/ic_check" />
        </layer-list>
    </item>

    <!-- Pressed State (Unchecked) -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#9E9E9E" />
            <solid android:color="@android:color/transparent" />
            <size android:width="32dp" android:height="32dp" />
        </shape>
    </item>

    <!-- Unchecked/Incomplete State -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#E0E0E0" />
            <solid android:color="@android:color/transparent" />
            <size android:width="32dp" android:height="32dp" />
        </shape>
    </item>
</selector>

